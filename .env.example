# ---------------------------------------------------------------------------
# MSAK IT Hub — copy this file to ".env" and fill in a key. Read ONLY by the
# chat backend (server-side); never bundled into the browser.
# ---------------------------------------------------------------------------

# Google Gemini — get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# Optional: OpenRouter (https://openrouter.ai/keys). When set, used instead of Gemini.
# OPENROUTER_API_KEY=""
# OPENROUTER_MODEL=openrouter/auto
